# KOZY — Firebase environment variables (Expo)
# Copy this file to `.env.local` and fill in the values from the Firebase console:
#   Project settings → General → Your apps → Web app → SDK setup and configuration
#
# After creating/changing .env.local, restart Expo with a clean cache:
#   npx expo start -c
#
# NOTE: All client-readable vars MUST be prefixed with EXPO_PUBLIC_ for Expo to expose them.

EXPO_PUBLIC_ENV=development

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
