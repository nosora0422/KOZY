rules_version = '2';

// KOZY Firestore security rules — derived from [ROLES] / [COLLECTIONS] in CLAUDE.md.
// Listings are publicly readable (guest browse). Writes require auth + ownership.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Reads the caller's user doc role. Only call where strictly needed (costs a read).
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users — public profile read; only the user (or admin) can write their doc.
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid);
      allow update, delete: if isSelf(uid) || isAdmin();

      // savedListings is private to the user.
      match /savedListings/{listingId} {
        allow read, write: if isSelf(uid);
      }
    }

    // listings — public read; owner-only create/update/delete.
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // chats — only participants can read/write the chat and its messages.
    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      function willBeParticipant() {
        return isSignedIn() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if isParticipant();
      allow create: if willBeParticipant();
      allow update: if isParticipant() || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function chatData() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if isSignedIn() && request.auth.uid in chatData().participants;
        allow create: if isSignedIn()
          && request.auth.uid in chatData().participants
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // reports — signed-in users can file; only admins can read/triage.
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
